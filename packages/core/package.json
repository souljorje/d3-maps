{
  "name": "@d3-maps/core",
  "type": "module",
  "version": "0.14.0",
  "private": false,
  "description": "Framework-agnostic utilities for building interactive SVG maps with D3",
  "author": "Georgii Bukharov <souljorje@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://d3-maps.netlify.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/souljorje/d3-maps.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/souljorje/d3-maps/issues"
  },
  "keywords": [
    "d3",
    "d3-geo",
    "svg",
    "map",
    "dataviz",
    "geojson",
    "topojson"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "style": "dist/style.css",
  "types": "dist/index.d.ts",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/d3-geo": "catalog:",
    "@types/d3-selection": "catalog:",
    "@types/d3-shape": "catalog:",
    "@types/d3-transition": "catalog:",
    "@types/d3-zoom": "catalog:",
    "@types/geojson": "catalog:",
    "@types/topojson-client": "catalog:",
    "@types/topojson-specification": "catalog:",
    "d3-geo": "catalog:",
    "d3-selection": "catalog:",
    "d3-shape": "catalog:",
    "d3-transition": "catalog:",
    "d3-zoom": "catalog:",
    "topojson-client": "catalog:"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  }
}
