{
  "name": "@d3-maps/vue",
  "type": "module",
  "version": "0.10.0",
  "private": false,
  "description": "Vue bindings for @d3-maps/core to build reactive D3 SVG maps",
  "author": "Georgii Bukharov <souljorje@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://d3-maps.netlify.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/souljorje/d3-maps.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/souljorje/d3-maps/issues"
  },
  "keywords": [
    "vue",
    "d3",
    "svg",
    "map"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "style": "dist/style.css",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "typecheck": "vue-tsc --noEmit",
    "typecheck:test": "vue-tsc -p tsconfig.test.json --noEmit",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "vue": "catalog:"
  },
  "dependencies": {
    "@d3-maps/core": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:",
    "@vue/test-utils": "catalog:",
    "jsdom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unplugin-vue": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
